{
  "name": "kunqiong-color-tools",
  "private": true,
  "version": "1.0.0",
  "description": "一个功能齐全的色彩工坊，支持颜色拾取、转换、配色及彩图转黑白等功能。",
  "author": "FullStack-Guardian",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"electron .\"",
    "electron:build": "npm run build && electron-builder",
    "build:dir": "npm run build && electron-builder --dir",
    "build:pack": "electron-builder --prepackaged dist_portable/win-unpacked",
    "test": "vitest run",
    "i18n:build": "node scripts/build-locales-from-table.cjs",
    "i18n:fetch": "node scripts/fetch-translations.cjs",
    "i18n:fetch-all": "node scripts/fetch-all-locales.cjs",
    "i18n:zh-TW": "node scripts/zh-CN-to-zh-TW.cjs",
    "i18n:check": "node scripts/check-i18n.mjs"
  },
  "build": {
    "appId": "com.kunqiong.color-workshop",
    "productName": "色彩工坊",
    "directories": {
      "output": "dist_portable"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "axios": "^1.13.2",
    "clsx": "^2.1.0",
    "colord": "^2.9.3",
    "crypto-js": "^4.2.0",
    "framer-motion": "^12.23.26",
    "i18next": "^25.8.17",
    "lucide-react": "^0.363.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.6",
    "react-router-dom": "^7.11.0",
    "tailwind-merge": "^2.2.2",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitalets/google-translate-api": "^9.2.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^29.1.1",
    "electron-builder": "^24.13.3",
    "jest": "^29.7.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.2.2",
    "vite": "^5.2.2",
    "vitest": "^4.0.16"
  }
}
